{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "build/**", ".svelte-kit/**"],
      "env": [
        "INTERNAL_API_URL",
        "PUBLIC_API_BASE_URL",
        "PUBLIC_PARTYKIT_HOST",
        "PUBLIC_SENTRY_DSN",
        "SENTRY_AUTH_TOKEN",
        "SENTRY_ORG",
        "SENTRY_PROJECT_API",
        "SENTRY_PROJECT_BUYER",
        "SENTRY_PROJECT_SELLER",
        "SENTRY_PROJECT_ADMIN"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "lint:fix": {
      "cache": false
    },
    "format": {
      "cache": false
    },
    "format:check": {},
    "test": {
      "dependsOn": ["^test"],
      "outputs": ["coverage/**"],
      "env": ["DATABASE_URL", "JWT_SECRET", "PAYMENT_WEBHOOK_SECRET"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "env": [
        "INTERNAL_API_URL",
        "PUBLIC_API_BASE_URL",
        "PUBLIC_PARTYKIT_HOST",
        "PUBLIC_SENTRY_DSN"
      ]
    }
  }
}