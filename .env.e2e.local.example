# =====================================================================
# .env.e2e.local — overrides for "local-real" Playwright E2E mode
#
# Usage:
#   1. cp .env.e2e.local.example .env.e2e.local   (or copy values into .env)
#   2. docker compose up -d postgres
#   3. pnpm run e2e:local:setup
#   4. pnpm run test:e2e:local
#
# This file is consumed automatically by `pnpm run test:e2e:local`
# (loaded via dotenv-cli). It does NOT replace .env for normal dev.
# =====================================================================

# --- Target switch ---------------------------------------------------
# "local" forces helpers + playwright.config.ts to use local URLs and
# starts the Node API runner instead of the staging cloud.
E2E_TARGET=local

# --- API + Portal URLs (override only if you change ports) ----------
E2E_API_URL=http://localhost:8787
E2E_BUYER_URL=http://localhost:4301
E2E_ADMIN_URL=http://localhost:4302
E2E_SELLER_URL=http://localhost:4303

# --- API runtime required ------------------------------------------
DATABASE_URL=postgresql://jeevatix:jeevatix@localhost:5432/jeevatix
JWT_SECRET=local-e2e-jwt-secret-change-me
PAYMENT_WEBHOOK_SECRET=local-e2e-payment-webhook-secret
APP_ENVIRONMENT=development
APP_VERSION=local-e2e

# --- E2E helpers ---------------------------------------------------
# Bypass auth/register/login rate limit so Playwright can run in parallel.
PLAYWRIGHT_E2E=1
# Surface verify-email + reset-password tokens in JSON responses so
# password-reset-flow.spec.ts can complete without a real mailbox.
AUTH_EXPOSE_DEBUG_TOKENS=1

# --- CORS (local portal origins) -----------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:4301,http://localhost:4302,http://localhost:4303

# --- Frontend public build-time env --------------------------------
PUBLIC_API_BASE_URL=http://localhost:8787

# --- Optional (leave blank unless you exercise these features) ----
# Email send paths will throw EMAIL_API_KEY_MISSING when triggered. Tests
# that need email confirmation should rely on AUTH_EXPOSE_DEBUG_TOKENS.
EMAIL_API_KEY=
EMAIL_FROM=
# R2 upload tests require a real bucket binding; keep blank for now.
UPLOAD_PUBLIC_URL=
# Buyer live-availability websocket. Local PartyKit is not started by
# default; broadcast is short-circuited when these are unset.
PARTYKIT_HOST=
PARTY_SECRET=
PUBLIC_PARTYKIT_HOST=
